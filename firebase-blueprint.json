{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User settings and profile information",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "settings": {
          "type": "object",
          "properties": {
            "theme": { "type": "string", "enum": ["light", "dark", "system"] },
            "notifications": { "type": "boolean" },
            "defaultCategory": { "type": "string" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "createdAt"]
    },
    "Task": {
      "title": "Task",
      "description": "A collaborative task document",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "description": { "type": "string" },
        "summary": { "type": "string" },
        "completed": { "type": "boolean" },
        "priority": { "type": "string", "enum": ["low", "medium", "high"] },
        "category": { "type": "string" },
        "ownerId": { "type": "string" },
        "collaborators": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" },
        "dueDate": { "type": "number" },
        "reminderTime": { "type": "number" }
      },
      "required": ["text", "completed", "priority", "category", "ownerId", "createdAt"]
    },
    "Comment": {
      "title": "Comment",
      "description": "A comment on a task",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userPhoto": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["userId", "text", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": { "schema": "User", "description": "User profiles" },
    "tasks/{taskId}": { "schema": "Task", "description": "Shared tasks" },
    "tasks/{taskId}/comments/{commentId}": { "schema": "Comment", "description": "Task discussions" }
  }
}
